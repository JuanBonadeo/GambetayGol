# Base de datos — Neon o cualquier PostgreSQL
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Auth — generá un string random de 32+ caracteres
BETTER_AUTH_SECRET="your-32-chars-random-string-here"

# URL pública del sitio (sin slash final)
# En Vercel: la URL de tu deployment, ej: https://gambetaygol.vercel.app
# En local: http://localhost:3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"
BETTER_AUTH_URL="http://localhost:3000"

# Admin
ADMIN_EMAIL="admin@gambetaygol.com"
ADMIN_PASSWORD="supersecretpassword123!"

# WhatsApp — número para pedidos (formato internacional sin + ni espacios)
NEXT_PUBLIC_WHATSAPP_NUMBER="5493413758317"

# Cloudinary — https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
